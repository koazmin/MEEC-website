# Copy to .env.local for local dev, and add these in Vercel → Project → Settings → Environment Variables.

# cPanel mailbox SMTP — from cPanel → Email Accounts → Connect Devices / Configure Mail Client.
SMTP_HOST=mail.meec.edu.mm
SMTP_PORT=465
SMTP_USER=inquiry@meec.edu.mm
SMTP_PASS=the-mailbox-password

# Where inquiry emails are delivered. Optional — defaults to SMTP_USER.
INQUIRY_TO_EMAIL=inquiry@meec.edu.mm
