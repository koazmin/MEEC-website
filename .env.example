# Copy to .env.local for local dev, and add these in Vercel → Project → Settings → Environment Variables.

# Resend API key — create a free key at https://resend.com (API Keys).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where inquiry emails are delivered (your MEEC inbox).
INQUIRY_TO_EMAIL=you@example.com

# The "from" address shown on inquiry emails.
# For a quick start use Resend's shared sender (only delivers to your own account email):
#   RESEND_FROM=MEEC Website <onboarding@resend.dev>
# For production, verify meec.edu.mm in Resend and use e.g.:
#   RESEND_FROM=MEEC Website <no-reply@meec.edu.mm>
RESEND_FROM=MEEC Website <onboarding@resend.dev>
